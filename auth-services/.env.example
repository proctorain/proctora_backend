FRONTEND_URL=http://localhost:3000
PORT=5500
# Your PostgreSQL connection
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/authdb"

# Three DIFFERENT secrets - generate each with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace_this_with_random_string_1
JWT_ACCESS_EXPIRES=15m

JWT_REFRESH_SECRET=replace_this_with_random_string_2
JWT_REFRESH_EXPIRES=7d

JWT_VERIFY_SECRET=replace_this_with_random_string_3

# Redis
REDIS_URL=redis://localhost:6379

# Gmail - use an App Password, NOT your real Gmail password
# Google Account → Security → 2FA → App Passwords
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your16charapppassword
