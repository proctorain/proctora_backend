generator client {
  provider = "prisma-client-js"
  // This tells Prisma: generate a JavaScript client I can use in my code
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Userss {
  id                String    @id @default(uuid())
  // String primary key, auto-generates a UUID like "a1b2c3d4-..."

  email             String    @unique
  // @unique = PostgreSQL creates an index, duplicate emails throw an error

  password          String
  // We store the bcrypt HASH here, never the real password

  verified          Boolean   @default(false)
  // Starts as false. Set to true when user clicks the email link.

  verificationToken String?
  // The ? means nullable. We store the JWT token we emailed them.

  resetToken        String?
  // Nullable. Stores SHA256 hash of the password reset token.

  resetTokenExpiry  DateTime?
  // Nullable. When the reset token expires (1 hour from creation).

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  // @updatedAt = Prisma auto-updates this field on every save
}